##### STARBASE EXTENDED 3.0 AQUATICS STARBASE ASSETS #####

@flowmap_speed = 0.17
@flowmap_intensity =  0.3

# OUTPOST
# FRAME
	entity = {
		name = "aquatic_01_starbase_outpost_entity"
		pdxmesh = "aquatic_01_outpost_frame_mesh"
	}
	
# SECTION
	entity = {
		name = "aquatic_01_starbase_outpost_section_entity"
		pdxmesh = "aquatic_01_outpost_mesh"
	
		#locator = { name = "slot1"				position = { 0	0  0 } }
		
		locator = { name = "medium_gun_01"    position = { 0 0 0 } rotation = { 0 0 0 } }
	
		default_state = "idle"
		state = { name = "idle" state_time = 5
			 event = { time = 0 node = "light_locator_01" particle = "aquatic_01_ship_light_effect" keep_particle = yes trigger_once = yes }
			 event = { time = 0 node = "light_locator_02" particle = "aquatic_01_ship_light_effect" keep_particle = yes trigger_once = yes }
			 event = { time = 0 node = "light_locator_03" particle = "aquatic_01_ship_light_effect" keep_particle = yes trigger_once = yes }
			 start_event = { trigger_once = yes sound = { soundeffect = "amb_aquatic_starbase_hum_01" } }
		}
			game_data = {
				emissive_recolor_crunch = 2.0
			}		
	}

