# HEADQUARTERS
# FRAME
	entity = {
		name = "cybernetics_01_starbase_stronghold_entity"
		pdxmesh = "cybernetics_01_citadel_frame_mesh"
		cull_radius = 22

		game_data = {
			emissive_recolor_crunch = 1.0
		}
	}

# SECTION
	entity = {
		name = "cybernetics_01_starbase_stronghold_section_entity"
		pdxmesh = "cybernetics_01_citadel_mesh"
		
		locator = { name = "medium_gun_01"    position = { 0 0 0 } rotation = { 0 0 0 } }

		default_state = "idle"
		state = { name = "idle" state_time = 5
			 event = { time = 0 node = "light_locator_01" particle = "cybernetics_01_ship_light_effect" keep_particle = yes trigger_once = yes }
			 event = { time = 0 node = "light_locator_02" particle = "cybernetics_01_ship_light_effect" keep_particle = yes trigger_once = yes }
			 event = { time = 0 node = "light_locator_03" particle = "cybernetics_01_ship_light_effect" keep_particle = yes trigger_once = yes }
		}		
		game_data = {
			uv_animation_speed 		= 0.07
			uv_animation_direction 	= { 1.4 0.0 }
		}
	}


