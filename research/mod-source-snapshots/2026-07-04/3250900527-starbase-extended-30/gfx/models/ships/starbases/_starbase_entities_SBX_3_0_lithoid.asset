##### STARBASE EXTENDED 3.0 LITHOID STARBASE ASSETS #####

# OUTPOST
# FRAME
entity = {
	name = "lithoid_01_starbase_outpost_entity"
	pdxmesh = "lithoid_01_outpost_frame_mesh"
	
}
# SECTION
entity = {
	name = "lithoid_01_starbase_outpost_section_entity"
	pdxmesh = "lithoid_01_outpost_mesh"
	
	locator = { name = "medium_gun_01"    position = { 0 0 0 } rotation = { 0 0 0 } }

	default_state = "idle"
	state = { name = "idle" animation = idle
#		event = { time = 0 node = inner_section particle = "lithoid_01_starbase_core_effect" keep_particle = yes trigger_once = yes }
		start_event = { trigger_once = yes sound = { soundeffect = "starbase_hum_stage_01" } }
	}
	attach = { "inner_section" = "lithoid_01_starbase_core_entity"	}	
	
		game_data = {
			emissive_recolor_crunch = 2.0
		}		
}

