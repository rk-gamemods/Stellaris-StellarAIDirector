# cross rings
entity = {
	name = "starlifter_01_o_star_entity"
	scale = 2.88
	cull_radius = 1000

	locator = { name = "ring1" position = { 0 0 0 } rotation = { 0 45 0 } }
	locator = { name = "ring2" position = { 0 0 0 } rotation = { 0 -45 0 } }

	attach = { "ring1" = "starlifter_accelerator_ring_entity" }
	attach = { "ring2" = "starlifter_accelerator_ring_entity" }
}

# 4 titans
entity = {
	name = "starlifter_02_o_star_construction_entity"
	scale = 2.88
	cull_radius = 1000

	locator = { name = "acce1" position = { 0 0 0 } rotation = { 0 0 0 } }

	attach = { "acce1" = "starlifter_energytwo_entity" }
}

# cross rings + 4 titans
entity = {
	name = "starlifter_02_o_star_entity"
	scale = 2.88
	cull_radius = 1000

	locator = { name = "ring1" position = { 0 0 0 } rotation = { 0 45 0 } }
	locator = { name = "ring2" position = { 0 0 0 } rotation = { 0 -45 0 } }
	locator = { name = "acce1" position = { 0 0 0 } rotation = { 0 0 0 } }
	locator = { name = "flux1" position = { 0 0 0 } rotation = { 0 45 0 } }		# 45 degree flux to titans
	locator = { name = "flux2" position = { 0 0 0 } rotation = { 0 -45 0 } }

	attach = { "ring1" = "starlifter_accelerator_ring_entity" }	# cross rings
	attach = { "ring2" = "starlifter_accelerator_ring_entity" }
	attach = { "acce1" = "starlifter_energytwo_entity" }		# 4 titans
	attach = { "flux1" = "nova_outbursts_entity" }				# 45 degree flux to titans
	attach = { "flux2" = "nova_outbursts_entity" }
}

# polar ring
