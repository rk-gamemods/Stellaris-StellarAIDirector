	locator = { name = "ring3" position = { 0 0 0 } rotation = { 90 90 0 } }

	attach = { "ring3" = "starlifter_polartechring_entity" }
}

# cross rings + 4 titans + polar ring
entity = {
	name = "starlifter_03_o_star_entity"
	scale = 2.88
	cull_radius = 1000

	locator = { name = "ring1" position = { 0 0 0 } rotation = { 0 45 0 } }
	locator = { name = "ring2" position = { 0 0 0 } rotation = { 0 -45 0 } }
	locator = { name = "acce1" position = { 0 0 0 } rotation = { 0 0 0 } }
	locator = { name = "ring3" position = { 0 0 0 } rotation = { 90 90 0 } }

	locator = { name = "flux1" position = { 0 0 0 } rotation = { 0 45 0 } }		# 45 degree flux to titans
	locator = { name = "flux2" position = { 0 0 0 } rotation = { 0 -45 0 } }

	attach = { "ring1" = "starlifter_accelerator_ring_entity" }
	attach = { "ring2" = "starlifter_accelerator_ring_entity" }
	attach = { "acce1" = "starlifter_energytwo_entity" }
	attach = { "ring3" = "starlifter_polartechring_entity" }

	attach = { "flux1" = "nova_outbursts_entity" }			# 45 degree flux to titans
	attach = { "flux2" = "nova_outbursts_entity" }
}

# polar stations
entity = {
	name = "starlifter_04_o_star_construction_entity"
	scale = 2.88
	cull_radius = 1000

	locator = { name = "comp1" position = { 0 0 0 } rotation = { 0 0 0 } }			# 2 stations on poles
	locator = { name = "drain1" position = { 0 160 0 } rotation = { 0 -90 0 } }		# upper drainer
	locator = { name = "drain2" position = { 0 -160 0 } rotation = { 0 90 0 } }		# lower drainer

	attach = { "comp1" = "starlifter_compressors_entity" }	# 2 stations on poles # do these on next stage?
	attach = { "drain1" = "starlifter_drain_entity" }		# fungoid mining station
	attach = { "drain2" = "starlifter_drain_entity" }		# fungoid mining station
}

# cross rings + 4 titans + polar ring + polar stations 
entity = {
	name = "starlifter_04_o_star_entity"
	scale = 2.88
	cull_radius = 1000

	locator = { name = "ring1" position = { 0 0 0 } rotation = { 0 45 0 } }		# the ring between the lower and upper Titans diagonally
	locator = { name = "ring2" position = { 0 0 0 } rotation = { 0 -45 0 } }	# the ring between the upper and lower Titans diagonally
	locator = { name = "acce1" position = { 0 0 0 } rotation = { 0 0 0 } }		# 4 Titans
	locator = { name = "ring3" position = { 0 0 0 } rotation = { 90 90 0 } }	# poles tech ring
	locator = { name = "comp1" position = { 0 0 0 } rotation = { 0 0 0 } }		# 2 stations on poles
	locator = { name = "drain1" position = { 0 160 0 } rotation = { 0 -90 0 } }	# upper drainer
	locator = { name = "drain2" position = { 0 -160 0 } rotation = { 0 90 0 } }	# lower drainer

	locator = { name = "flux1" position = { 0 0 0 } rotation = { 0 45 0 } }		# 45 degree flux to titans
	locator = { name = "flux2" position = { 0 0 0 } rotation = { 0 -45 0 } }
	locator = { name = "hflux" position = { 0 0 0 } rotation = { 0 0 90 } }		# horizontal flux
	locator = { name = "cloud" position = { 0 0 0 } rotation = { 0 0 0 } }		# cloud effect

	attach = { "ring1" = "starlifter_accelerator_ring_entity" }		# outer ring without habitable sections
	attach = { "ring2" = "starlifter_accelerator_ring_entity" }		# outer ring without habitable sections
	attach = { "acce1" = "starlifter_energytwo_entity" }			# 4 Titans above and below equator
	attach = { "ring3" = "starlifter_polartechring_entity" }		# poles ring between 2 stations
	attach = { "comp1" = "starlifter_compressors_entity" }			# 2 stations on poles
	attach = { "drain1" = "starlifter_drain_entity" }				# fungoid mining station
	attach = { "drain2" = "starlifter_drain_entity" }				# fungoid mining station

	attach = { "flux1" = "nova_outbursts_entity" }					# 45 degree flux to titans
	attach = { "flux2" = "nova_outbursts_entity" }
	attach = { "vflux" = "nova_outbursts_entity" }					# fire vertical
	attach = { "cloud" = "starlifter_cloud_effect" }				# cloud effect
}

# left and right 2 stations & final ring
entity = {
	name = "starlifter_05_o_star_construction_entity"
	scale = 2.88
	cull_radius = 1000

	locator = { name = "comp2" position = { 0 0 0 } rotation = { 0 0 90 } }			# 2 stations on cross
	locator = { name = "ring4" position = { 0 0 0 } rotation = { 0 0 90 } }			# vertical ring between 4 titans
	locator = { name = "drain3" position = { 160 0 0 } rotation = { 90 0 0 } }		# left drainer
	locator = { name = "drain4" position = { -160 0 0 } rotation = { -90 0 0 } }	# right drainer

	attach = { "comp2" = "starlifter_compressors_entity" }		# 2 stations on rings cross
	attach = { "ring4" = "starlifter_polartechring_entity" }	# outer vertical ring segment between 4 titans
	attach = { "drain3" = "starlifter_drain_entity" }			# fungoid mining station
	attach = { "drain4" = "starlifter_drain_entity" }			# fungoid mining station
}

# cross rings + 4 titans + polar ring + polar stations + 2 stations & final ring
entity = {
	name = "starlifter_05_o_star_entity"
	scale = 2.88
	cull_radius = 1000

	locator = { name = "ring1" position = { 0 0 0 } rotation = { 0 45 0 } }			# the ring between the lower and upper Titans diagonally
	locator = { name = "ring2" position = { 0 0 0 } rotation = { 0 -45 0 } }		# the ring between the upper and lower Titans diagonally
	locator = { name = "acce1" position = { 0 0 0 } rotation = { 0 0 0 } }			# 4 Titans
	locator = { name = "ring3" position = { 0 0 0 } rotation = { 90 90 0 } }		# poles tech ring
	locator = { name = "comp1" position = { 0 0 0 } rotation = { 0 0 0 } }			# 2 stations on poles
	locator = { name = "comp2" position = { 0 0 0 } rotation = { 0 0 90 } }			# 2 stations on cross
	locator = { name = "ring4" position = { 0 0 0 } rotation = { 0 0 90 } }			# vertical ring between 4 titans
	locator = { name = "drain1" position = { 0 160 0 } rotation = { 0 -90 0 } }		# upper drainer
	locator = { name = "drain2" position = { 0 -160 0 } rotation = { 0 90 0 } }		# lower drainer
	locator = { name = "drain3" position = { 160 0 0 } rotation = { 90 0 0 } }		# left drainer
	locator = { name = "drain4" position = { -160 0 0 } rotation = { -90 0 0 } }	# right drainer

	locator = { name = "flux1" position = { 0 0 0 } rotation = { 0 45 0 } }			# 45 degree flux to titans
	locator = { name = "flux2" position = { 0 0 0 } rotation = { 0 -45 0 } }
	locator = { name = "hflux" position = { 0 0 0 } rotation = { 0 0 90 } }			# horizontal flux
	locator = { name = "cloud" position = { 10 0 0 } rotation = { 0 0 0 } }			# cloud effect
	locator = { name = "shield" position = { 0 0 0 } }								# shield around star

	attach = { "ring1" = "starlifter_accelerator_ring_entity" }				# outer ring without habitable sections
	attach = { "ring2" = "starlifter_accelerator_ring_entity" }				# outer ring without habitable sections
	attach = { "acce1" = "starlifter_energytwo_entity" }					# 4 Titans above and below equator
	attach = { "comp1" = "starlifter_compressors_entity" }					# 2 stations on poles
	attach = { "ring3" = "starlifter_polartechring_entity" }				# poles ring between 2 stations
	attach = { "comp2" = "starlifter_compressors_entity" }					# 2 stations on rings cross
	attach = { "ring4" = "starlifter_polartechring_entity" }				# outer vertical ring segment between 4 titans
	attach = { "drain1" = "starlifter_drain_entity" }						# fungoid mining station
	attach = { "drain2" = "starlifter_drain_entity" }						# fungoid mining station
	attach = { "drain3" = "starlifter_drain_entity" }						# fungoid mining station
	attach = { "drain4" = "starlifter_drain_entity" }						# fungoid mining station

	attach = { "flux1" = "nova_outbursts_entity" }							# 45 degree flux to titans
	attach = { "flux2" = "nova_outbursts_entity" }
	attach = { "vflux" = "nova_outbursts_entity" }							# vertical flux
	attach = { "hflux" = "nova_outbursts_entity" }							# horizontal flux
	attach = { "cloud" = "starlifter_cloud_effect" }						# cloud effect
	attach = { "shield" = "starlifter_planet_shield_alt_ambient_entity" }	# shield effect from starlifter_effect.asset
}
