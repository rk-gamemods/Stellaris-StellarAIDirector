

@mainScale = 10 # overall entity sizing

# torus
@anim = giga_orbit_0_3 # 0.3 eccentricity
@inclination = 27 # 90 * eccentricity
@orbitScale = 10 # orbit size scale
@objectScale = 0.025 # scale of orbiting objects

########################################################################################################################
# template entities which are referenced via clone

# orbit base
entity = {
    name = giga_dyson_forest_orbit_template
    locator = { name = origin position = { 0 0 0 } }
    default_state = "idle"
    state = { name = "idle" state_time = 10 }
}
entity = {
    name = giga_dyson_forest_orbit_part_template
    pdxmesh = giga_orbit
    scale = @orbitScale
    playback_rate = 0.4

    #attach = { orbit = giga_dyson_forest_rock }
    get_state_from_parent = no

    default_state = idle
}

# composite rock base
entity = {
    name = giga_dyson_forest_rock_template
    locator = { name = layer1 position = { 0 0 0 } }
    locator = { name = layer2 position = { 0 0 0 } scale = 1.1 }
    locator = { name = layer3 position = { 0 0 0 } scale = 1.25 }
    locator = { name = layer4 position = { 0 0 0 } scale = 1.4 }

    default_state = idle
    state = { name = "idle" state_time = 10 }

    scale = @objectScale
}

########################################################################################################################
# objects
########################################################################################################################

entity = {
    name = giga_dyson_forest_rock
    pdxmesh = asteroid_01_mesh
    scale = @objectScale

    default_state = idle
    state = { name = "idle" state_time = 10 }
}
entity = {
    name = giga_dyson_forest_rock_2
    pdxmesh = asteroid_ice_large_01_mesh
    scale = @objectScale

    default_state = idle
    state = { name = "idle" state_time = 10 }
}

