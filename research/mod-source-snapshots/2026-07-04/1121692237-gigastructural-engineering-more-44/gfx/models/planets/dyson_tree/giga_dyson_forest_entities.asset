########################################################################################################################
# test arrays

@testZ1 = -100
@testZ2 = 0
@testZ3 = 100
@testS1 = -150
@testS2 = -50
@testS3 = 50
@testS4 = 150
entity = {
    name = giga_dyson_forest_rock_test

    locator = { name = r1s1 position = { @testS1 0 @testZ1 } }
    locator = { name = r1s2 position = { @testS2 0 @testZ1 } }
    locator = { name = r1s3 position = { @testS3 0 @testZ1 } }
    locator = { name = r1s4 position = { @testS4 0 @testZ1 } }
    attach = { r1s1 = giga_dyson_forest_rock_1_stage_1 }
    attach = { r1s2 = giga_dyson_forest_rock_1_stage_2 }
    attach = { r1s3 = giga_dyson_forest_rock_1_stage_3 }
    attach = { r1s4 = giga_dyson_forest_rock_1_stage_4 }

    locator = { name = r2s1 position = { @testS1 0 @testZ2 } }
    locator = { name = r2s2 position = { @testS2 0 @testZ2 } }
    locator = { name = r2s3 position = { @testS3 0 @testZ2 } }
    locator = { name = r2s4 position = { @testS4 0 @testZ2 } }
    attach = { r2s1 = giga_dyson_forest_rock_2_stage_1 }
    attach = { r2s2 = giga_dyson_forest_rock_2_stage_2 }
    attach = { r2s3 = giga_dyson_forest_rock_2_stage_3 }
    attach = { r2s4 = giga_dyson_forest_rock_2_stage_4 }

    locator = { name = r3s1 position = { @testS1 0 @testZ3 } }
    locator = { name = r3s2 position = { @testS2 0 @testZ3 } }
    locator = { name = r3s3 position = { @testS3 0 @testZ3 } }
    locator = { name = r3s4 position = { @testS4 0 @testZ3 } }
    attach = { r3s1 = giga_dyson_forest_rock_3_stage_1 }
    attach = { r3s2 = giga_dyson_forest_rock_3_stage_2 }
    attach = { r3s3 = giga_dyson_forest_rock_3_stage_3 }
    attach = { r3s4 = giga_dyson_forest_rock_3_stage_4 }
}

